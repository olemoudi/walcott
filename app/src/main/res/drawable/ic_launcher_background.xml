<?xml version="1.0" encoding="utf-8"?>
<!--
  Adaptive-icon background: the app's signature violet→indigo diagonal gradient (the same
  brush the in-app hero cards use), so the launcher icon reads as the same product. Fills the
  full 108dp canvas the way an adaptive background must.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="6" android:startY="0"
                android:endX="102" android:endY="108">
                <item android:offset="0" android:color="#6A5AF0" />
                <item android:offset="1" android:color="#2A1466" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
