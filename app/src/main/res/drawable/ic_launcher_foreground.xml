<?xml version="1.0" encoding="utf-8"?>
<!--
  Walcott logo: two overlapping checkmarks forming a W ("parental approval, twice").
  The front (mint) check leans on the back (teal) one — its descender starts on the
  teal ascender — so the silhouette reads as a lowercase-style W with a lowered middle
  apex while the duotone keeps the two checks legible. Artwork sits inside the 66dp
  safe zone of the 108dp adaptive-icon canvas.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path
        android:pathData="M29.5,55 L39.5,65 L58,43"
        android:strokeColor="#2EC4B6"
        android:strokeWidth="7.5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />
    <path
        android:pathData="M49.5,53 L61.5,65 L78.5,42.5"
        android:strokeColor="#57D3A0"
        android:strokeWidth="7.5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />
</vector>
