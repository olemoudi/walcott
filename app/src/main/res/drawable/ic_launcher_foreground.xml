<?xml version="1.0" encoding="utf-8"?>
<!--
  Walcott mark: a guardian shield (the app protects a child's device) holding the twin
  checkmarks that form a W ("Walcott", and "parental approval, twice"). White shield outline
  + mint/teal checks on the violet gradient background — the app's identity in one glance.
  Artwork sits inside the 66dp safe zone of the 108dp adaptive-icon canvas.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <!-- Shield: rounded-top badge tapering to a soft point, ~0.88 width:height. -->
    <path
        android:pathData="M32,37 Q32,31 38,31 L70,31 Q76,31 76,37 L76,55 Q76,70 54,81 Q32,70 32,55 Z"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="4.5"
        android:strokeLineJoin="round" />
    <!-- Back check (teal). -->
    <path
        android:pathData="M40,54 L47,61 L58,48"
        android:strokeColor="#2EC4B6"
        android:strokeWidth="6"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />
    <!-- Front check (mint), leaning on the back one to read as a W. -->
    <path
        android:pathData="M50,54 L58,62 L69,47"
        android:strokeColor="#57D3A0"
        android:strokeWidth="6"
        android:strokeLineCap="round"
        android:strokeLineJoin="round" />
</vector>
